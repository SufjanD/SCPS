# Smart Campus Parking System - Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Sensor webhook API key (for real IoT sensor integration)
SENSOR_API_KEY=sensor-key-2024

# Optional: If integrating a real Vehicle Registry API
# VEHICLE_REGISTRY_API_URL=https://your-university.edu/api/vehicles
# VEHICLE_REGISTRY_API_KEY=your-key-here
